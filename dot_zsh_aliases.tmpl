# --- navigation & filesystem ---

# Smart cd dispatcher
cdd() {
  local target="$1"
  case "$target" in
    sun)
      cd "$HOME/projects/sun-asterisk" ;;
    "")
      echo "Usage: cdd <name>"; return 1 ;;
    *)
      echo "Unknown cdd target: $target"; return 1 ;;
  esac
}

# Create dir + cd
mkcd() { mkdir -p "$1" && cd "$1"; }

# Create file + parent dirs
touchp() { mkdir -p "$(dirname "$1")" && touch "$1"; }

# Go up N levels (default 1)
up() { cd "$(printf '../%.0s' $(seq 1 "${1:-1}") )"; }

# Listing helpers
alias l='ls -lah'
alias la='ls -A'
alias ld='ls -d */'

# --- docker & docker compose ---

# Container & image info
alias dps='docker ps'
alias dpa='docker ps -a'
alias dim='docker images'
alias dnet='docker network ls'

# Container lifecycle (cẩn thận với *all alias)
alias drm='docker rm'
alias drmi='docker rmi'
alias dstp='docker stop'
alias drmall='docker rm $(docker ps -aq)'
alias drmiall='docker rmi $(docker images -q)'

# Exec & logs
alias dexec='docker exec -it'
alias dlogs='docker logs -f'

# Docker compose
alias dco='docker compose'

# Compose flows
alias dcup='docker compose up -d'
alias dcupd='docker compose up'
alias dcdown='docker compose down --remove-orphans'
alias dclogs='docker compose logs -f'
alias dcb='docker compose build'

# Exec shell vào service: dcsh <service>, dcbash <service>
dcsh() {
  if [[ -z "$1" ]]; then
    echo "Usage: dcsh <service>" >&2
    return 1
  fi
  set -x
  docker compose exec "$1" sh
}

dcbash() {
  if [[ -z "$1" ]]; then
    echo "Usage: dcbash <service>" >&2
    return 1
  fi
  set -x
  docker compose exec "$1" bash
}

# --- package manager (universal bun/pnpm/yarn/npm) ---

p() {
  if [[ -f bun.lockb ]]; then
    command bun "$@"
  elif [[ -f pnpm-lock.yaml ]]; then
    command pnpm "$@"
  elif [[ -f yarn.lock ]]; then
    command yarn "$@"
  elif [[ -f package-lock.json ]]; then
    command npm "$@"
  else
    command pnpm "$@"
  fi
}

# --- shell/system utility ---

# Clear & exit
alias c='clear'
alias x='exit'

# Reload zsh config
alias reload='source "$HOME/.zshrc"'

# Show shell and PATH-related info
alias whichshell='echo $SHELL && echo ${ZDOTDIR:-$HOME}'
alias envpath='echo $PATH | tr ":" "\n"'

# System info (for linux distro)
alias cpuinfo='lscpu'
alias meminfo='free -h'
alias diskinfo='df -h'

# Package manager update (for linux apt)
alias update='sudo apt update && sudo apt upgrade -y'

# --- search/grep utilities ---

# Search within alias list
alias ag='alias | grep'

# History & search
alias h='history'
alias hg='history | grep'

# Grep with color and line numbers
alias grep='grep --color=auto'
alias egrep='egrep --color=auto'
alias fgrep='fgrep --color=auto'

# Find files by name (case-insensitive): ff pattern
ff() {
  if [[ -z "$1" ]]; then
    echo "Usage: ff <pattern>" >&2
    return 1
  fi
  find . -iname "*$1*"
}
