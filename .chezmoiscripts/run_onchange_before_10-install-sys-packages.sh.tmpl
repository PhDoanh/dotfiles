#!/bin/bash
# installation list: {{ (index .packages .chezmoi.os "system") | join "," }}
set -euo pipefail

run_as_root() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
  else
    command -v sudo >/dev/null 2>&1 ||
      { echo "sudo is required when not running as root" >&2; exit 1; }
    sudo "$@"
  fi
}

{{- if eq .chezmoi.os "darwin" }}
brew install {{ (index .packages.darwin "system") | join " " }}
{{- else if eq .chezmoi.os "linux" }}
run_as_root apt-get update
run_as_root apt-get install -y {{ (index .packages.linux "system") | join " " }}
{{- end }}
